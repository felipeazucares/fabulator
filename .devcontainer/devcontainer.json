{
  "name": "Fabulator Dev Container",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "api",
  "workspaceFolder": "/app",
  //"initializeCommand": ".devcontainer/init-firewall.sh",

  "features": {
    "ghcr.io/anthropics/devcontainer-features/claude-code:latest": {}
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.black-formatter",
        "charliermarsh.ruff",
        "mongodb.mongodb-vscode",
        "humao.rest-client"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "editor.formatOnSave": true
      }
    }
  },

  "forwardPorts": [8000],
 "postCreateCommand": "apt-get install -y iptables && .devcontainer/init-firewall.sh && pip install --no-cache-dir -r requirements.txt"  "remoteUser": "root"
}