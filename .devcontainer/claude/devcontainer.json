{
  "name": "Fabulator Claude Code",
  "dockerComposeFile": ["../../docker-compose.yml"],
  "service": "dev-claude",
  "workspaceFolder": "/code",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylance",
        "charliermarsh.ruff",
        "tamasfe.even-better-toml",
        "redhat.vscode-yaml"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/bin/python3",
        "editor.formatOnSave": true,
        "editor.rulers": [88]
      }
    }
  },
  "shutdownAction": "none"
}