{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "*": "allow",
      "rm *": "ask",
      "rm -rf *": "deny",
      "rmdir *": "ask",
      "git push *": "ask",
      "git push --force *": "deny",
      "git rebase *": "ask",
      "git reset --hard *": "ask",
      "git clean *": "ask",
      "chmod *": "ask",
      "sudo *": "deny"
    },
    "edit": "allow"
  }
}
