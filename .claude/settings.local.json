{
  "permissions": {
    "allow": [
      "Bash(pip3 list:*)",
      "Bash(git:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'if git rev-parse --abbrev-ref HEAD | grep -q \"^main$\\|^master$\"; then echo \"BLOCKED: never commit to main\"; exit 1; fi'"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat .claude/context.md 2>/dev/null && echo '## Git state' && git branch --show-current && git status --short | head -10"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cp \"$CLAUDE_TRANSCRIPT_PATH\" .claude/backups/last-transcript.jsonl 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}