# ===========================================
# Fabulator Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values

# -------------------------------------------
# MongoDB Atlas Connection
# -------------------------------------------
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
MONGO_DETAILS=mongodb+srv://username:password@cluster0.abc123.mongodb.net/fabulator?retryWrites=true&w=majority

# -------------------------------------------
# Redis (for token blacklist)
# -------------------------------------------
# Local: redis://localhost:6379
# Redis Cloud: redis://username:<password>@<host>:<port>
REDISHOST=redis://localhost:6379

# -------------------------------------------
# JWT Authentication
# -------------------------------------------
# Generate a secure secret key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generate-a-secure-secret-key

# JWT algorithm (HS256 is standard)
ALGORITHM=HS256

# Token expiration in minutes (e.g., 30 = 30 minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# -------------------------------------------
# CORS Allowed Origins
# -------------------------------------------
# Comma-separated list of allowed frontend origins
# Dev: http://localhost:3000 (CRA) or http://localhost:5173 (Vite)
# Prod: https://yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# -------------------------------------------
# Rate Limiting
# -------------------------------------------
# Max login attempts per minute per IP (increase for test environments)
LOGIN_RATE_LIMIT=5/minute

# -------------------------------------------
# Debug Mode
# -------------------------------------------
# Set to True for verbose logging (disable in production)
DEBUG=False

# -------------------------------------------
# Test User Credentials (for integration tests)
# -------------------------------------------
TESTUSERTOADD=test_user_1
TESTPWDTOADD=test_password_1
TESTUSERTOADD2=test_user_2
TESTPWDTOADD2=test_password_2
TESTPWDTOCHANGE=new_test_password
